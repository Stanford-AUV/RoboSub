{
  "name": "RoboSub Development",
  "dockerFile": "Dockerfile",
  "build": {
    "args": {
      "WORKSPACE": "${containerWorkspaceFolder}"
    }
  },
  "remoteUser": "ros",
  "runArgs": [
    // GPU support: Uncomment one of the following when NVIDIA Container Toolkit is installed:
    // For newer nvidia-container-toolkit: "--gpus", "all",
    // For older nvidia-docker2: "--runtime=nvidia",
    //"--gpus", "all",
    "--runtime=nvidia",
    "--publish=4222:4222",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp:unconfined",
    "--security-opt=apparmor:unconfined",
    "--ipc=host",
    "--net=host",
    "--privileged",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix",
    "--mount=type=bind,source=${env:HOME},target=/host_home,readonly",
    "--volume=/dev/bus/usb:/dev/bus/usb",
    "--volume=/dev/ttyACM0:/dev/ttyACM0",
    "--volume=/dev/ttyACM1:/dev/ttyACM1",
    "--volume=/dev/ttyACM2:/dev/ttyACM2",
    "--volume=/dev/ttyACM3:/dev/ttyACM3",
    "--volume=/dev/ttyACM4:/dev/ttyACM4",
    "--volume=/dev/ttyACM5:/dev/ttyACM5",
    "--volume=/dev/ttyUSB_teensy:/dev/ttyUSB_teensy",
    "--volume=/dev/ttyUSB0:/dev/ttyUSB0",
    "--volume=/dev/ttyUSB1:/dev/ttyUSB1",
    "--volume=/dev/ttyUSB2:/dev/ttyUSB2",
    "--volume=/dev/ttyUSB3:/dev/ttyUSB3",
    "--volume=/dev/ttyUSB4:/dev/ttyUSB4",
    "--volume=/dev/ttyUSB5:/dev/ttyUSB5",
    "--device-cgroup-rule=c 189:* rmw",
    // Add NVIDIA library mounts:
    "--volume=/usr/local/cuda-12:/usr/local/cuda-12:ro",
    "--volume=/usr/local/cuda-12:/usr/local/cuda:ro",  // Symlink for compatibility
    "--volume=/usr/lib/aarch64-linux-gnu/nvidia:/usr/lib/aarch64-linux-gnu/nvidia:ro",
    "--volume=/usr/lib/aarch64-linux-gnu/tegra:/usr/lib/aarch64-linux-gnu/tegra:ro",
    // uncomment to use intel iGPU
    // "--device=/dev/dri"
  ],
  "containerEnv": {
    "DISPLAY": "localhost:10.0", // "host.docker.internal:0",
    "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
    "XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}",
    "PULSE_SERVER": "${localEnv:PULSE_SERVER}",
    "LIBGL_ALWAYS_SOFTWARE": "1",
    "CUDA_HOME": "/usr/local/cuda-12",
    "PATH": "/usr/local/cuda-12/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
    "LD_LIBRARY_PATH": "/usr/local/cuda-12/lib64:/usr/lib/aarch64-linux-gnu/nvidia:/usr/lib/aarch64-linux-gnu/tegra"
  },
  // Set *default* container specific settings.json values on container create.
  "customizations": {
    "vscode": {
      "extensions": [
        "althack.ament-task-provider",
        "betwo.b2-catkin-tools",
        "DotJoshJohnson.xml",
        "ms-azuretools.vscode-docker",
        "ms-iot.vscode-ros",
        "ms-python.black-formatter",
        "ms-python.python",
        "ms-vscode.cpptools",
        "redhat.vscode-yaml",
        "smilerobotics.urdf",
        "streetsidesoftware.code-spell-checker",
        "twxs.cmake",
        "yzhang.markdown-all-in-one",
        "zachflower.uncrustify",
        "njpwerner.autodocstring"
      ]
    }
  },
  "postCreateCommand": "/home/ros/env/bin/python3 -m pip install --no-cache-dir -r /workspaces/Robosub/requirements.txt && /home/ros/env/bin/python3 -m pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu124"
}